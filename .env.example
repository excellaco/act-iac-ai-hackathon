# Local dev (Docker Compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/parcela

# Cloud Run (Cloud SQL Unix socket — set as DATABASE_URL in GitHub Secrets)
# DATABASE_URL=postgresql://parcela_app:PASSWORD@/parcela?host=/cloudsql/parcela-490518:us-central1:parcela

# CI migrations (TCP via Cloud SQL Auth Proxy — set as DATABASE_URL_MIGRATE in GitHub Secrets)
# DATABASE_URL_MIGRATE=postgresql://parcela_app:PASSWORD@127.0.0.1:5432/parcela
