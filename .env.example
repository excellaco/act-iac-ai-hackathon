# ── Local dev (Docker Compose) ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/parcela

# GCS bucket for zoning PDFs — leave unset to use local data/raw/zoning/ fallback
# RAW_DATA_BUCKET=parcela-490518-raw-data

# ── Production / CI (set these as GitHub Secrets, not in this file) ───────────
# DATABASE_URL=postgresql://parcela_app:PASSWORD@/parcela?host=/cloudsql/parcela-490518:us-central1:parcela
# DATABASE_URL_MIGRATE=postgresql://parcela_app:PASSWORD@127.0.0.1:5432/parcela
# GCP_PROJECT_ID=parcela-490518
# GCP_WORKLOAD_IDENTITY_PROVIDER=projects/1035403781322/locations/global/workloadIdentityPools/github-actions-pool/providers/github-provider
