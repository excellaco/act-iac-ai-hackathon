# ── Local dev (Docker Compose) ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/parcela

# GCS bucket for zoning PDFs — leave unset to use local data/raw/zoning/ fallback
# RAW_DATA_BUCKET=parcella-501012-raw-data

# ── Gemini pipeline tuning ───────────────────────────────────────────────────
# Maximum simultaneous Gemini API calls across all extraction stages (default: 5)
# GEMINI_CONCURRENCY=5
#
# Retry attempts on quota errors (429 RESOURCE_EXHAUSTED) with exponential
# backoff: ~1s → ~2s → ~4s → ~8s → ~16s → ~32s (default: 6, ~63s total)
# Set to 3 for faster failure in development; keep at 6+ in production.
# GEMINI_MAX_RETRIES=6

# ── Production / CI (set these as GitHub Secrets, not in this file) ───────────
# DATABASE_URL=postgresql://parcela_app:PASSWORD@/parcela?host=/cloudsql/parcella-501012:us-central1:parcela
# DATABASE_URL_MIGRATE=postgresql://parcela_app:PASSWORD@127.0.0.1:5432/parcela
# GCP_PROJECT_ID=parcella-501012
# GCP_WORKLOAD_IDENTITY_PROVIDER=projects/59092929765/locations/global/workloadIdentityPools/github-actions-pool/providers/github-provider
