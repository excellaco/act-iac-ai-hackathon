{
  "name": "hackathon-temp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config db/seeds/jurisdictions.ts",
    "db:seed:scores": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config db/seeds/realScores.ts",
    "db:seed:synthetic": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config db/seeds/syntheticJurisdictions.ts",
    "db:seed:market": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config db/seeds/marketData.ts",
    "db:seed:feasibility": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config db/seeds/feasibilityOutputs.ts",
    "db:seed:all": "npm run db:seed && npm run db:seed:scores && npm run db:seed:synthetic && npm run db:seed:market && npm run db:seed:feasibility",
    "pipeline:parse": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/parse.ts",
    "pipeline:zones": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/zones.ts",
    "pipeline:extract": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/extract.ts",
    "pipeline:load": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/load.ts",
    "pipeline:score": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/score.ts",
    "pipeline:purge": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/purge.ts",
    "ocr:pdf": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/ocr-pdf.ts",
    "pipeline:run": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/run-pipeline.ts",
    "pipeline:page-resolve": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/page-resolve.ts",
    "score:zones": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/score-zones.ts",
    "pipeline:restore-mocks": "cp data/mocks/*.json data/extractions/",
    "artifacts:sync": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/artifacts-sync.ts",
    "artifacts:migrate": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/migrate-artifacts.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@google-cloud/vertexai": "^1.10.0",
    "@google-cloud/vision": "^5.3.5",
    "@google/adk": "^0.5.0",
    "@types/leaflet": "^1.9.21",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "leaflet": "^1.9.4",
    "next": "16.2.10",
    "p-limit": "^3.1.0",
    "pdf-parse": "^1.1.4",
    "pg": "^8.13.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0"
  },
  "overrides": {
    "fast-xml-parser": "5.5.7",
    "protobufjs": "7.6.2",
    "@protobufjs/utf8": "1.1.1",
    "@grpc/grpc-js": "1.14.4",
    "hono": "4.12.27",
    "fast-uri": "3.1.3",
    "lodash-es": "4.18.1",
    "@mikro-orm/core": "6.6.15",
    "ws": "8.21.0",
    "path-to-regexp@^8.0.0": "8.4.0",
    "picomatch@^2.0.0": "2.3.2",
    "picomatch@^4.0.0": "4.0.4",
    "brace-expansion@^1.0.0": "1.1.13",
    "brace-expansion@^2.0.0": "2.0.3",
    "brace-expansion@^5.0.0": "5.0.7"
  },
  "devDependencies": {
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.11.13",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
